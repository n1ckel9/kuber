# Прод-конфиг сервера Кубер. На VPS: cp deploy/env.production.example server/.env  и заполни.
NODE_ENV=production
PORT=4000

# Постоянная БД — ВНЕ папки кода, чтобы git pull/деплой её не трогал.
DB_FILE=/opt/kuber/data/kuber.db

# Админ(ы) по e-mail (через запятую). Такой аккаунт видит вкладку «Админ».
ADMIN_EMAILS=gribioprime2@gmail.com

# Напоминания заказчикам по циклу (0 — выключить).
REMINDERS_ENABLED=1

# CORS. Мобильное приложение шлёт запросы без Origin, поэтому * безопасно.
CORS_ORIGIN=*

# --- Реальный вход по коду (без этого OTP работает только в dev-режиме) ---
# Вариант А: SMS.ru — заведи аккаунт, вставь api_id:
SMSRU_API_ID=
# Вариант Б (дешевле): Telegram Gateway — gatewayapi.telegram.org:
# TELEGRAM_GATEWAY_TOKEN=

# --- Пополнение монет (ЮKassa), опционально ---
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET=
