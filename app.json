{
  "expo": {
    "name": "Кубер",
    "slug": "vodovoz-services",
    "version": "0.3.8",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Кубер использует галерею для загрузки фото работ и документов для верификации."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ru.vodovoz.services",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Кубер использует галерею для загрузки фото работ и документов для верификации."
      }
    },
    "android": {
      "package": "ru.vodovoz.services",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ce1bb3b2-d3df-42a6-b0d7-a838eff9cf41"
      }
    }
  }
}
